# If you want to suggest changes, please send PR on
# https://altlinux.space/rirusha/Cassette to altlinux branch 

%define _unpackaged_files_terminate_build 1

%define app_id space.rirusha.Cassette.Devel

%ifarch %e2k
%define for_e2k true
%else
%define for_e2k false
%endif

Name: cassette
Version: @VERSION@
Release: alt@RELEASE@

Summary: Unofficial Yandex Music client (Devel build)
License: GPL-3.0-or-later
Group: Sound
URL: https://altlinux.space/rirusha/Cassette
VCS: https://altlinux.space/rirusha/Cassette.git

Source: %name-%version.tar

BuildRequires(pre): rpm-macros-meson
BuildRequires: rpm-build-vala
BuildRequires: rpm-build-gir
BuildRequires: meson
BuildRequires: vala
BuildRequires: vala-tools
BuildRequires: gobject-introspection-devel
BuildRequires: blueprint-compiler
BuildRequires: gir(Adw) = 1
BuildRequires: pkgconfig(gee-0.8)
BuildRequires: pkgconfig(libadwaita-1)
BuildRequires: pkgconfig(libtape-0)
BuildRequires: pkgconfig(libcase-0)
BuildRequires: typelib(Case) = 0
BuildRequires: pkgconfig(webkitgtk-6.0)
BuildRequires: gettext-devel
%ifdef with_check
BuildRequires: /usr/bin/appstream
BuildRequires: /usr/bin/glib-compile-schemas
%endif

%description
%summary.

%prep
%setup

%build
%meson -Dnightly=true -De2k=%for_e2k
%meson_build

%install
%meson_install
%find_lang %name

%check
%meson_test

%files -f %name.lang
%_bindir/%name
%_datadir/glib-2.0/schemas/%app_id.gschema.xml
%_datadir/metainfo/%app_id.metainfo.xml
%_desktopdir/%app_id.desktop
%_iconsdir/hicolor/*/apps/%app_id.svg
%_iconsdir/hicolor/*/apps/%app_id-symbolic.svg
