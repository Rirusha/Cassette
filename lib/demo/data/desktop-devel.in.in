[Desktop Entry]
# Translators: app name should be translated
Name=Cassette Demo (Devel)
Comment=libcassette demo (Devel build)
# Translators: keep number of ';'
Keywords=demo;libcassette;
Exec=libcassette-demo %U
Icon=@APP_ID_RELEVANT@
Terminal=false
Type=Application
Categories=GNOME;GTK;
StartupNotify=true
X-GNOME-UsesNotifications=true
X-SingleMainWindow=true
X-Purism-FormFactor=Workstation;Mobile;
X-GNOME-Gettext-Domain=cassette-demo
