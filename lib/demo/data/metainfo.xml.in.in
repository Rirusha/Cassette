<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <name>Cassette Demo</name>
  <id>@APP_ID@</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <summary>libcassette demo application</summary>
  <description>
    <p>
      libcassette demo application
    </p>
  </description>
  <launchable type="desktop-id">@APP_ID@.desktop</launchable>
  <developer id="space.rirusha">
    <name>Vladimir Romanov</name>
    <name xml:lang="ru">Владимир Романов</name>
  </developer>
  <translation type="gettext">cassette</translation>
  <custom>
    <value key="Purism::form_factor">mobile</value>
  </custom>
  <requires>
    <display_length compare="ge">360</display_length>
  </requires>
  <recommends>
    <control>keyboard</control>
    <control>pointing</control>
    <control>touch</control>
  </recommends>
  <branding>
    <color type="primary" scheme_preference="light">#fee372</color>
    <color type="primary" scheme_preference="dark">#dd624b</color>
  </branding>
  <url type="homepage">@HOMEPAGE@</url>
  <url type="bugtracker">@BUGTRACKER@</url>
  <url type="help">@HELP@</url>
  <releases>
  </releases>
  <categories>
    <category>GNOME</category>
    <category>GTK</category>
  </categories>
  <provides>
    <binary>libcassette-demo</binary>
  </provides>
</component>
