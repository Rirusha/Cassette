#: src/widgets/auth.vala:41
msgid ""
"Choose a way to log in to the app. You can log in via your Yandex account or "
"with your token."
msgstr ""
"Επιλέξτε τρόπο εισόδου στην εφαρμογή. Μπορείτε να συνδεθείτε μέσω του "
"λογαριασμού σας Yandex ή με το διακριτικό σας."

#: src/widgets/auth.vala:44
msgid "You need your Yandex music token to login."
msgstr "Χρειάζεστε το διακριτικό Yandex music για να συνδεθείτε."

#: src/widgets/auth.vala:111
msgid "Failed to login. Probably wrong token"
msgstr "Αποτυχία εισόδου. Πιθανώς λάθος διακριτικό"

#: src/widgets/auth.vala:116
#, c-format
msgid "Bad status code: %i"
msgstr "Ελαττωματικός κωδικός κατάστασης: %i"

#: src/widgets/auth.vala:121
msgid "Connection problems"
msgstr "Προβλήματα σύνδεσης"

#~ msgid "yandex;yandex music;yam;music;"
